{
  "name": "gripr-frontend",
  "version": "1.0.0",
  "description": "AI-powered bike tire pressure recommendation UI",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "generate:api": "openapi-typescript http://localhost:3000/openapi.json -o src/api/generated.ts"
  },
  "keywords": ["react", "vite", "typescript", "bootstrap", "bike", "tire-pressure"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bootstrap": "^5.3.3",
    "openapi-fetch": "^0.13.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "lucide-react": "^0.468.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "jsdom": "^25.0.1",
    "msw": "^2.6.8",
    "openapi-typescript": "^7.4.4",
    "typescript": "~5.6.2",
    "vite": "^6.0.1",
    "vitest": "^2.1.8",
    "@testing-library/user-event": "^14.5.2"
  }
}