{
  "name": "gripr-frontend",
  "version": "1.0.0",
  "description": "AI-powered bike tire pressure recommendation UI",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "serve -s dist -l $PORT",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "generate:api": "openapi-typescript http://localhost:3000/openapi.json -o src/api/generated.ts"
  },
  "keywords": [
    "react",
    "vite",
    "typescript",
    "bootstrap",
    "bike",
    "tire-pressure"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bootstrap": "^5.3.3",
    "lucide-react": "^0.468.0",
    "openapi-fetch": "^0.13.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "serve": "^14.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitejs/plugin-react": "^4.3.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-sonarjs": "^4.0.3",
    "globals": "^17.6.0",
    "jsdom": "^25.0.1",
    "msw": "^2.6.8",
    "openapi-typescript": "^7.4.4",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.59.4",
    "vite": "^6.0.1",
    "vitest": "^2.1.8"
  }
}
